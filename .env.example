# Cloud Microservices Architecture & Integration Framework
# Copy this file to `.env` and adjust as needed. The orchestrator,
# docker-compose, and individual services all read these variables.

# --- External (host) ports ---
API_GATEWAY_PORT=8000
SERVICE_A_PORT=8001
SERVICE_B_PORT=8002
CPP_WORKER_PORT=8003
FAULT_INJECTOR_PORT=8004

# --- Internal service hostnames (resolved on the docker-compose network) ---
API_GATEWAY_HOST=api-gateway
SERVICE_A_HOST=service-a
SERVICE_B_HOST=service-b
CPP_WORKER_HOST=cpp-worker
FAULT_INJECTOR_HOST=fault-injector

# --- Logging ---
LOG_LEVEL=INFO

# --- Orchestrator / recovery ---
HEALTH_POLL_INTERVAL_SECONDS=5
HEALTH_FAILURE_THRESHOLD=3
RECOVERY_BACKOFF_SECONDS=2

# --- Metrics collector ---
METRICS_OUTPUT_PATH=./metrics/metrics.json
METRICS_SCRAPE_INTERVAL_SECONDS=10
